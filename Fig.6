      }
    },
    .groups = "drop"
  ) %>%
  mutate(
    p_adj = p.adjust(p, method = "fdr"),
    star = case_when(
      is.na(p_adj)     ~ "",
      p_adj < 0.001    ~ "***",
      p_adj < 0.01     ~ "**",
      p_adj < 0.05     ~ "*",
      TRUE             ~ ""
    ),
    Treatment_full = factor(recode(Treatment, !!!label_map), levels = cond_order_full)
  )

# =========================
# 7) Spaghetti plot corrigé
