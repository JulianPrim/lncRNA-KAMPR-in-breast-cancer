
# ------------------------------------------------------------
# Analysis of Wu et al. breast tumor scRNA-seq atlas
# ------------------------------------------------------------
# 29/05/2026
# Julian Primig
# This script generates Fig. 6A, 6C and 6D.
#
# It compares KAMPR/LINC00885-positive and -negative ER+ cancer epithelial
# cells, generating half-violin plots for steroid signaling, endocrine
# resistance and luminal differentiation genes.
#
# It also analyzes treated T-47D and ZR-75-1 cells from Ors et al. https://doi.org/10.1093/nar/gkac908, producing
# UMAPs, KAMPR-positive cell fraction plots over time, and a heatmap of KAMPR
# expression changes relative to untreated control cells.
# ------------------------------------------------------------

# ============================================================
# Half-violin plot with:
# - KAMPR+ on the left / KAMPR- on the right for each gene
# Fig6A is Based on KAMPR / LINC00885 analysis in ER+ Cancer Epithelial Cells differential expression analysis
# Generation of half violin plots for steroid and endocrine identity genes 
# ============================================================

suppressPackageStartupMessages({
  library(Seurat)
  library(dplyr)
  library(tidyr)
  library(ggplot2)
  library(tibble)
  library(gghalves)
  library(patchwork)
  library(grid)
})

# ------------------------------------------------------------
# 0) Parameters
# ------------------------------------------------------------

seurat_file <- "seurat_obj.rds"

gene_lnc   <- "LINC00885"
gene_label <- "KAMPR"

gene_annotation <- tibble::tribble(
  ~Gene,      ~Pathway,
  "ESR1",     "Canonical ER signaling",
  "AR",       "Steroid / apocrine response",
  "PGRMC1",   "Steroid / apocrine response",
  "PIP",      "Steroid / apocrine response",
  "APOD",     "Steroid / apocrine response",
  "HOXB13",   "Endocrine resistance-associated",
  "BCAR4",    "Endocrine resistance-associated",
  "LMTK3","Endocrine resistance-associated",
  "TFF3",     "Endocrine resistance-associated",
  "SCGB2A2",  "Luminal secretory differentiation",
  "SCGB2A1",  "Luminal secretory differentiation",
  "SCGB1D2",  "Luminal secretory differentiation"
)

pathway_order <- c(
  "Canonical ER signaling",
  "Steroid / apocrine response",
  "Endocrine resistance-associated",
  "Luminal secretory differentiation"
)

cols_kampr <- c(
  "KAMPR+" = "#7FA06A",
  "KAMPR-" = "#A77EAA"
)

pathway_cols <- c(
  "Canonical ER signaling"            = "#5B7FA3",
  "Steroid / apocrine response"       = "#C97C6D",
  "Endocrine resistance-associated"   = "#9B7AA5",
  "Luminal secretory differentiation" = "#7FA6A3"
)

outdir <- "KAMPR_half_violin_modules_independent_scales"
dir.create(outdir, showWarnings = FALSE, recursive = TRUE)

# ------------------------------------------------------------
# 1) Load Seurat object
# ------------------------------------------------------------

seurat_obj <- readRDS(seurat_file)

if (!inherits(seurat_obj, "Seurat")) {
  stop("The loaded object is not a Seurat object.")
}

DefaultAssay(seurat_obj) <- "RNA"

message("Loaded object: ", seurat_file)
message("Cells: ", ncol(seurat_obj))
message("Features: ", nrow(seurat_obj))

# ------------------------------------------------------------
# 2) Check metadata and genes
# ------------------------------------------------------------

if (!all(c("subtype", "celltype_major") %in% colnames(seurat_obj@meta.data))) {
  stop("Metadata columns 'subtype' and/or 'celltype_major' are missing.")
}

if (!(gene_lnc %in% rownames(seurat_obj))) {
  stop(
    gene_lnc, " not found in object. Try:\n",
    "grep('LINC00885|KAMPR|00885', rownames(seurat_obj), value = TRUE)"
  )
}

genes_present <- gene_annotation$Gene[gene_annotation$Gene %in% rownames(seurat_obj)]
genes_missing <- setdiff(gene_annotation$Gene, genes_present)

if (length(genes_missing) > 0) {
  warning("Missing genes skipped: ", paste(genes_missing, collapse = ", "))
}

if (length(genes_present) == 0) {
  stop("None of the requested genes were found in the object.")
}

gene_annotation <- gene_annotation %>%
  filter(Gene %in% genes_present) %>%
  mutate(
    Pathway = factor(Pathway, levels = pathway_order)
  )

message("Genes used: ", paste(gene_annotation$Gene, collapse = ", "))

# ------------------------------------------------------------
# 3) Subset ER+ Cancer Epithelial cells
# ------------------------------------------------------------

er_epi_obj <- subset(
  seurat_obj,
  subset = subtype == "ER+" & celltype_major == "Cancer Epithelial"
)

DefaultAssay(er_epi_obj) <- "RNA"

message("ER+ Cancer Epithelial cells: ", ncol(er_epi_obj))

if (ncol(er_epi_obj) == 0) {
  stop("No ER+ Cancer Epithelial cells found with subtype == 'ER+' & celltype_major == 'Cancer Epithelial'.")
}

er_epi_obj <- NormalizeData(er_epi_obj, verbose = FALSE)

# ------------------------------------------------------------
# 4) Define KAMPR+ and KAMPR- cells
# ------------------------------------------------------------

lnc_expr <- FetchData(er_epi_obj, vars = gene_lnc)[, 1]

er_epi_obj$KAMPR_status <- ifelse(lnc_expr > 0, "KAMPR+", "KAMPR-")
er_epi_obj$KAMPR_status <- factor(er_epi_obj$KAMPR_status, levels = c("KAMPR+", "KAMPR-"))

message("KAMPR groups:")
print(table(er_epi_obj$KAMPR_status))

# ------------------------------------------------------------
# 5) Fetch expression data
# ------------------------------------------------------------

plot_df <- FetchData(
  object = er_epi_obj,
  vars = c(gene_annotation$Gene, "KAMPR_status")
) %>%
  rownames_to_column("Cell") %>%
  pivot_longer(
    cols = all_of(gene_annotation$Gene),
    names_to = "Gene",
    values_to = "Expression"
  ) %>%
  left_join(gene_annotation, by = "Gene") %>%
  mutate(
    Pathway      = factor(Pathway, levels = pathway_order),
    KAMPR_status = factor(KAMPR_status, levels = c("KAMPR+", "KAMPR-"))
  )

# ------------------------------------------------------------
# 6) Statistics
# ------------------------------------------------------------

stat_df <- plot_df %>%
  group_by(Pathway, Gene) %>%
  summarise(
    p_value = tryCatch(
      wilcox.test(Expression ~ KAMPR_status)$p.value,
      error = function(e) NA_real_
    ),
    .groups = "drop"
  ) %>%
  mutate(
    p_adj = p.adjust(p_value, method = "BH"),
    stars = case_when(
      is.na(p_adj) ~ "ns",
      p_adj < 1e-4 ~ "****",
      p_adj < 1e-3 ~ "***",
      p_adj < 1e-2 ~ "**",
      p_adj < 0.05 ~ "*",
      TRUE ~ "ns"
    )
  )

write.csv(
  stat_df,
  file = file.path(outdir, "KAMPR_half_violin_stats.csv"),
  row.names = FALSE
)

# ------------------------------------------------------------
# 7) Helper: make one module block
# ------------------------------------------------------------

make_module_block <- function(module_name, show_y = FALSE) {
  
  # ------------------------
  # Data for this module
  # ------------------------
  mod_genes <- gene_annotation %>%
    filter(Pathway == module_name) %>%
    pull(Gene)
  
  mod_df <- plot_df %>%
    filter(Pathway == module_name, Gene %in% mod_genes) %>%
    mutate(
      Gene = factor(Gene, levels = mod_genes),
      x = as.numeric(factor(Gene, levels = mod_genes)),
      group_id = interaction(Gene, KAMPR_status, drop = TRUE)
    )
  
  mod_stats <- stat_df %>%
    filter(Pathway == module_name, Gene %in% mod_genes) %>%
    mutate(
      Gene = factor(Gene, levels = mod_genes),
      x = as.numeric(factor(Gene, levels = mod_genes))
    )
  
  # ------------------------
  # Medians = colored points
  # ------------------------
  med_df <- mod_df %>%
    group_by(Gene, x, KAMPR_status) %>%
    summarise(
      med = median(Expression, na.rm = TRUE),
      .groups = "drop"
    ) %>%
    mutate(
      x_point = ifelse(KAMPR_status == "KAMPR+", x - 0.12, x + 0.12)
    )
  
  # ------------------------
  # Star positions per gene
  # ------------------------
  gene_max_df <- mod_df %>%
    group_by(Gene, x) %>%
    summarise(
      ymax_gene = max(Expression, na.rm = TRUE),
      .groups = "drop"
    )
  
  mod_range <- range(mod_df$Expression, na.rm = TRUE)
  mod_span  <- max(mod_range[2] - mod_range[1], 0.5)
  
  mod_stats_plot <- mod_stats %>%
    left_join(gene_max_df, by = c("Gene", "x")) %>%
    mutate(
      star_y  = ymax_gene + 0.10 * mod_span,
      blank_y = ymax_gene + 0.20 * mod_span
    )
  
  # ------------------------
  # Main plot
  # ------------------------
  p_main <- ggplot() +
    geom_blank(
      data = mod_stats_plot,
      aes(x = x, y = blank_y)
    ) +
    gghalves::geom_half_violin(
      data = mod_df %>% filter(KAMPR_status == "KAMPR+"),
      aes(
        x = x,
        y = Expression,
        fill = KAMPR_status,
        group = group_id
      ),
      side = "l",
      trim = TRUE,
      scale = "width",
      width = 0.84,
      alpha = 0.95,
      color = "#2F2F2F",
      linewidth = 0.30,
      show.legend = TRUE
    ) +
    gghalves::geom_half_violin(
      data = mod_df %>% filter(KAMPR_status == "KAMPR-"),
      aes(
        x = x,
        y = Expression,
        fill = KAMPR_status,
        group = group_id
      ),
      side = "r",
      trim = TRUE,
      scale = "width",
      width = 0.84,
      alpha = 0.95,
      color = "#2F2F2F",
      linewidth = 0.30,
      show.legend = TRUE
    ) +
    geom_point(
      data = med_df,
      aes(x = x_point, y = med, fill = KAMPR_status),
      shape = 21,
      size = 1.8,
      stroke = 0.22,
      color = "black",
      inherit.aes = FALSE,
      show.legend = FALSE
    ) +
    geom_text(
      data = mod_stats_plot,
      aes(x = x, y = star_y, label = stars),
      size = 2.6,
      fontface = "bold",
      vjust = 0,
      color = "black",
      inherit.aes = FALSE
    ) +
    scale_fill_manual(
      values = cols_kampr,
      breaks = c("KAMPR+", "KAMPR-"),
      drop = FALSE,
      name = NULL
    ) +
    scale_x_continuous(
      breaks = seq_along(mod_genes),
      labels = mod_genes,
      expand = expansion(add = c(0.45, 0.45))
    ) +
    labs(
      x = NULL,
      y = if (show_y) "norm LogUMI/cell" else NULL,
      title = NULL
    ) +
    theme_classic(base_size = 8) +
    theme(
      plot.background  = element_rect(fill = "white", color = NA),
      panel.background = element_rect(fill = "white", color = NA),
      panel.grid = element_blank(),
      plot.title = element_blank(),
      
      axis.text.x  = element_blank(),
      axis.ticks.x = element_blank(),
      axis.line.x  = element_blank(),
      
      axis.text.y = if (show_y) {
        element_text(size = 7, color = "black")
      } else {
        element_blank()
      },
      axis.ticks.y = if (show_y) {
        element_line(color = "black")
      } else {
        element_blank()
      },
      axis.line.y = if (show_y) {
        element_line(color = "black")
      } else {
        element_blank()
      },
      axis.title.y = if (show_y) {
        element_text(size = 9, color = "black", margin = margin(r = 8))
      } else {
        element_blank()
      },
      
      legend.position = "bottom",
      legend.text = element_text(size = 7.5),
      legend.key.height = unit(0.24, "cm"),
      legend.key.width  = unit(0.45, "cm"),
      legend.spacing.x  = unit(0.12, "cm"),
      legend.margin     = margin(0, 0, 0, 0),
      
      # reduced inter-module spacing
      plot.margin = margin(4, 1, 0, 1)
    ) +
    guides(
      fill = guide_legend(
        nrow = 1,
        byrow = TRUE,
        override.aes = list(alpha = 1)
      )
    )
  
  # ------------------------
  # Tile strip underneath
  # ------------------------
  n_genes <- length(mod_genes)
  
  p_tile <- ggplot() +
    geom_rect(
      aes(
        xmin = 0.55,
        xmax = n_genes + 0.45,
        ymin = 0,
        ymax = 1
      ),
      fill = pathway_cols[as.character(module_name)],
      color = NA
    ) +
    scale_x_continuous(
      breaks = seq_along(mod_genes),
      labels = mod_genes,
      expand = expansion(add = c(0.45, 0.45))
    ) +
    scale_y_continuous(
      limits = c(0, 1),
      breaks = NULL,
      labels = NULL,
      expand = c(0, 0)
    ) +
    labs(x = NULL, y = NULL) +
    theme_classic(base_size = 8) +
    theme(
      plot.background  = element_rect(fill = "white", color = NA),
      panel.background = element_rect(fill = "white", color = NA),
      
      axis.line = element_blank(),
      axis.ticks = element_blank(),
      axis.text.y = element_blank(),
      
      axis.text.x = element_text(
        angle = 45,
        hjust = 1,
        vjust = 1,
        size = 8.5,
        color = "black",
        face = "italic"
      ),
      
      # reduced inter-module spacing
      plot.margin = margin(0, 1, 4, 1)
    )
  
  p_main / p_tile +
    plot_layout(heights = c(9.0, 0.35))
}

# ------------------------------------------------------------
# 8) Build all module blocks
# ------------------------------------------------------------

module_levels_present <- gene_annotation %>%
  distinct(Pathway) %>%
  pull(Pathway) %>%
  as.character()

module_levels_present <- pathway_order[pathway_order %in% module_levels_present]

module_sizes <- gene_annotation %>%
  dplyr::count(Pathway, name = "n") %>%
  dplyr::mutate(Pathway = as.character(Pathway)) %>%
  dplyr::arrange(match(Pathway, module_levels_present)) %>%
  dplyr::pull(n)

plot_list <- vector("list", length(module_levels_present))

for (i in seq_along(module_levels_present)) {
  plot_list[[i]] <- make_module_block(
    module_name = module_levels_present[i],
    show_y = (i == 1)
  )
}

final_plot <- wrap_plots(
  plotlist = plot_list,
  nrow = 1,
  widths = module_sizes,
  guides = "collect"
) &
  theme(
    legend.position = "bottom",
    legend.justification = "center",
    legend.text = element_text(size = 7.5),
    legend.key.height = unit(0.24, "cm"),
    legend.key.width  = unit(0.45, "cm"),
    legend.spacing.x  = unit(0.12, "cm"),
    legend.margin     = margin(0, 0, 0, 0)
  )

print(final_plot)























