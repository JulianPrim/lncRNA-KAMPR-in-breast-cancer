    )
}

# =========================
# 1) Helpers: lecture SANS entête
# =========================
read_counts_noheader <- function(path) {
  dt <- fread(path, sep = "\t", header = FALSE, check.names = FALSE)
  genes <- dt[[1]]
  stopifnot(!anyDuplicated(genes))
  mat <- as.matrix(dt[, -1, with = FALSE])
  rownames(mat) <- genes
  Matrix(mat, sparse = TRUE)
}

read_meta_noheader <- function(path) {
  m <- fread(path, sep = "\t", header = FALSE, check.names = FALSE)
  stopifnot(ncol(m) >= 3)
  m <- as.data.frame(m[, 1:3])
  names(m) <- c("idx", "barcode", "label")
  m$barcode <- toupper(as.character(m$barcode))
  m$label   <- as.character(m$label)
  
  lab <- toupper(m$label)
  
  time <- ifelse(grepl("CTL", lab), "0h",
                 ifelse(grepl("-0?3$", lab), "3h",
                        ifelse(grepl("-0?6$", lab), "6h",
                               ifelse(grepl("-24$", lab), "24h",
                                      ifelse(grepl("-48$", lab), "48h",
                                             ifelse(grepl("-72$", lab), "72h", NA))))))
  
  m$Time <- factor(ifelse(is.na(time), "NA", time),
                   levels = c("0h", "3h", "6h", "24h", "48h", "72h", "NA"))
  
  m <- m[!is.na(m$barcode) & m$barcode != "", ]
  m <- m[!duplicated(m$barcode), ]
  rownames(m) <- m$barcode
  m
}

# =========================
# 2) Parse treatment / time
# =========================
parse_treatment <- function(x) {
  x <- toupper(as.character(x))
  out <- ifelse(grepl("CTL", x),
                "CTL",
                sub("^[A-Z0-9]+-([A-Z]+)-.*$", "\\1", x))
  out[!out %in% c("E", "T", "IC", "P", "D", "CTL", "EP", "ED")] <- NA_character_
  out
}

parse_time <- function(x) {
  x <- toupper(as.character(x))
  out <- ifelse(grepl("CTL", x),
                "0h",
                ifelse(grepl("-([0-9]+)$", x),
                       paste0(as.integer(sub("^.*-([0-9]+)$", "\\1", x)), "h"),
                       NA_character_))
  factor(out, levels = time_levels)
}

# =========================
# 3) Construit un Seurat par lot
# =========================
make_seurat_from_pair <- function(counts_path, meta_path, sample_id) {
  counts <- read_counts_noheader(counts_path)
  meta   <- read_meta_noheader(meta_path)
  
  n_cells_counts <- ncol(counts)
  n_cells_meta   <- nrow(meta)
  
  if (n_cells_counts != n_cells_meta) {
    nmin <- min(n_cells_counts, n_cells_meta)
    message(sprintf("[%s] counts=%d, meta=%d -> alignement sur %d",
                    sample_id, n_cells_counts, n_cells_meta, nmin))
    counts <- counts[, 1:nmin, drop = FALSE]
    meta   <- meta[1:nmin, , drop = FALSE]
  }
  
  colnames(counts) <- rownames(meta)
  meta$Sample <- sample_id
  
  CreateSeuratObject(
    counts = counts,
    meta.data = meta,
    project = paste0("T47D_", sample_id),
    min.cells = 3,
    min.features = 200
  )
}

# =========================
# 4) Lecture des 3 lots + fusion
# =========================
t47d1 <- make_seurat_from_pair(
  "GSM4681761_T47D_1_counts.txt.gz",
  "GSM4681761_T47D_1_metadata.txt.gz",
  "T47D_1"
)

t47d2 <- make_seurat_from_pair(
  "GSM4681761_T47D_2_counts.txt.gz",
  "GSM4681761_T47D_2_metadata.txt.gz",
  "T47D_2"
)

t47d3 <- make_seurat_from_pair(
  "GSM4681761_T47D_3_counts.txt.gz",
  "GSM4681761_T47D_3_metadata.txt.gz",
  "T47D_3"
)

t47d <- merge(
  t47d1,
  y = list(t47d2, t47d3),
  add.cell.ids = c("T47D1", "T47D2", "T47D3")
)

# Filtrer EP / ED
t47d$Treatment <- parse_treatment(t47d$label)
keep_cells <- !t47d$Treatment %in% c("EP", "ED") & !is.na(t47d$Treatment)
t47d <- subset(t47d, cells = colnames(t47d)[keep_cells])

# Recréer métadonnées propres
t47d$Treatment <- parse_treatment(t47d$label)
t47d$Time <- parse_time(t47d$label)
t47d$Treatment_full <- factor(recode(t47d$Treatment, !!!label_map), levels = cond_order_full)

# =========================
# 5) UMAP paper-like
# =========================
t47d <- NormalizeData(t47d, verbose = FALSE)
t47d <- FindVariableFeatures(t47d, nfeatures = 3000, selection.method = "vst", verbose = FALSE)
t47d <- ScaleData(t47d, features = VariableFeatures(t47d), verbose = FALSE)
t47d <- RunPCA(t47d, features = VariableFeatures(t47d), npcs = 40, verbose = FALSE)
t47d <- RunUMAP(t47d, dims = 1:30, n.neighbors = 30, min.dist = 0.3, verbose = FALSE)
t47d <- FindNeighbors(t47d, dims = 1:30, verbose = FALSE)
t47d <- FindClusters(t47d, resolution = 0.5, verbose = FALSE)

p_umap <- DimPlot(
  t47d,
  reduction = "umap",
  group.by = "Treatment_full",
  cols = pal_named,
  pt.size = 0.25,
  raster = FALSE,
  shuffle = TRUE
) +
  labs(title = "T-47D") +
  theme_umap_paper(base_size = 12) +
  guides(
    colour = guide_legend(
      override.aes = list(size = 4, alpha = 1)
    )
  )

print(p_umap)

# =========================
# 6) Analyse d’un gène : LINC00885
# =========================
gene <- "LINC00885"
stopifnot(gene %in% rownames(t47d))

df <- FetchData(t47d, vars = c(gene, "label")) %>%
  tibble::rownames_to_column("cell")

names(df)[2] <- "expr"

df$Treatment <- parse_treatment(df$label)
df$Time <- parse_time(df$label)

df <- df %>%
  filter(!is.na(Treatment), !Treatment %in% c("EP", "ED"), !is.na(Time)) %>%
  mutate(
    Treatment_full = factor(recode(Treatment, !!!label_map), levels = cond_order_full)
  )

# Résumés
summ <- df %>%
  group_by(Treatment, Time, Treatment_full) %>%
  summarise(
    n = n(),
    pct_pos  = mean(expr > 0, na.rm = TRUE),
    mean_pos = if (sum(expr > 0, na.rm = TRUE) > 0) mean(expr[expr > 0], na.rm = TRUE) else NA_real_,
    .groups = "drop"
  )

# Baseline contrôle
ctl_vec <- df$expr[df$Treatment == "CTL"]
ctl_pct <- mean(ctl_vec > 0, na.rm = TRUE)

# Tests Wilcoxon vs contrôle
p_tab <- df %>%
  filter(Treatment != "CTL") %>%
  group_by(Treatment, Time) %>%
  summarise(
    p = {
      y <- expr
      if (length(ctl_vec) > 2 && length(y) > 2) {
