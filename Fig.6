##############################
# Heatmap of KAMPR expression
# among KAMPR+ cells normalized as
# log2FC versus untreated control
##############################

suppressPackageStartupMessages({
  library(dplyr)
  library(tidyr)
  library(ggplot2)
  library(patchwork)
  library(scales)
  library(grid)
})

# =========================================================
# Settings
# =========================================================

# Keep only these time points
time_levels_small <- c("0h", "3h", "48h")

# Condition order
cond_order_full <- c("E2", "Tamoxifen", "Fulvestrant", "Progesterone", "DHT", "Control")

# More contrasted divergent color palette
fc_cols <- c(
  "#5F8A5A",   # strong negative
  "#DCE8D6",   # weak negative
  "beige",     # center
  "#B7CAD7",   # weak positive
  "#243B63"    # strong positive
)

# =========================================================
# Functions
# =========================================================

make_complete_mat_small <- function(df) {
  df %>%
    mutate(
      Treatment_full = factor(as.character(Treatment_full), levels = cond_order_full),
      Time = factor(as.character(Time), levels = time_levels_small)
    ) %>%
    filter(Time %in% time_levels_small) %>%
    complete(
      Treatment_full = factor(cond_order_full, levels = cond_order_full),
      Time = factor(time_levels_small, levels = time_levels_small)
    )
}

add_log2fc_vs_control <- function(summ, value_col = "mean_pos", pseudocount = 1e-6) {
  
  ctl_val <- summ %>%
    filter(as.character(Treatment_full) == "Control", as.character(Time) == "0h") %>%
    pull(.data[[value_col]])
  
  if (length(ctl_val) != 1 || !is.finite(ctl_val)) {
    stop("Unable to retrieve a unique value for Control 0h.")
  }
  
  summ %>%
    mutate(
      log2FC_vs_ctl0 = log2((.data[[value_col]] + pseudocount) / (ctl_val + pseudocount))
    )
}

plot_heatmap_fc_small <- function(
    summ,
    title = "KAMPR",
    value_col = "mean_pos",
    fc_name = "log2FC\nvs Control 0h",
    shared_limit = NULL,
    cross_on_na = TRUE
) {
  
  # Keep only the selected time points
  summ2 <- summ %>%
    filter(as.character(Time) %in% time_levels_small)
  
  ctl_val <- summ2 %>%
    filter(as.character(Treatment_full) == "Control", as.character(Time) == "0h") %>%
    pull(.data[[value_col]])
  
  if (length(ctl_val) != 1 || !is.finite(ctl_val)) {
    stop("Control 0h is missing or invalid.")
  }
  
  mat <- add_log2fc_vs_control(summ2, value_col = value_col) %>%
    make_complete_mat_small()
  
  mat <- mat %>%
    mutate(
      log2FC_vs_ctl0 = ifelse(
        is.na(.data[[value_col]]),
        NA_real_,
        log2((.data[[value_col]] + 1e-6) / (ctl_val + 1e-6))
      )
    )
  
  # Shared limit / contrast
  if (!is.null(shared_limit)) {
    lim <- shared_limit
  } else {
    vals <- abs(mat$log2FC_vs_ctl0[is.finite(mat$log2FC_vs_ctl0)])
    lim <- ifelse(length(vals) == 0, 1, max(0.25, unname(quantile(vals, 0.95, na.rm = TRUE))))
  }
  
  if (!is.finite(lim) || lim <= 0) lim <- 1
  
  # Control 0h reference cell
  ctl_cell <- mat %>%
    filter(Treatment_full == "Control", Time == "0h")
  
  # Missing-value cells
  na_cells <- mat %>%
    filter(is.na(log2FC_vs_ctl0))
  
  p <- ggplot(mat, aes(x = Time, y = Treatment_full)) +
    
    # General background
    geom_tile(
      fill = "#FCFCFC",
      color = "#F2F2F2",
      linewidth = 0.95
    ) +
    
    # Actual data tiles
    geom_tile(
      data = mat %>% filter(!is.na(log2FC_vs_ctl0)),
      aes(fill = log2FC_vs_ctl0),
      color = "white",
      linewidth = 0.95
    ) +
    
    # Discrete outline around the Control 0h reference cell
    geom_tile(
      data = ctl_cell,
      fill = NA,
      color = "lightgrey",
      linewidth = 0.8
    ) +
    
    scale_fill_gradientn(
      colours = fc_cols,
      values = scales::rescale(c(-lim, -0.20 * lim, 0, 0.20 * lim, lim)),
      limits = c(-lim, lim),
      oob = scales::squish,
      na.value = "#FCFCFC",
      name = fc_name
    ) +
    
    labs(
      title = title,
      x = NULL,
      y = NULL
    ) +
    
    coord_fixed() +
    theme_classic(base_size = 12) +
    theme(
      plot.title = element_text(face = "bold", hjust = 0.5, size = 18),
      axis.text.x = element_text(color = "black", size = 12),
      axis.text.y = element_text(color = "black", size = 12),
      axis.ticks = element_blank(),
      axis.line = element_blank(),
      panel.border = element_blank(),
      panel.background = element_rect(fill = "white", colour = NA),
      plot.background = element_rect(fill = "white", colour = NA),
      legend.title = element_text(size = 11),
      legend.text = element_text(size = 10),
      legend.key.height = unit(0.55, "cm"),
      legend.key.width = unit(0.38, "cm"),
      plot.margin = margin(6, 10, 6, 6)
    )
  
  # Add a subtle cross on missing-value cells
  if (cross_on_na) {
    p <- p +
      geom_text(
        data = na_cells,
        aes(x = Time, y = Treatment_full, label = "×"),
        inherit.aes = FALSE,
        color = "#CFCFCF",
        size = 4.2,
        fontface = "plain"
      )
  }
  
  p
}

# =========================================================
# Object checks
# =========================================================

stopifnot(
  exists("summ_t47d"),
  exists("summ_zr")
)

# =========================================================
# Compute a shared color scale limit across the selected time points
# =========================================================

tmp_t47d <- summ_t47d %>%
  filter(as.character(Time) %in% time_levels_small) %>%
  add_log2fc_vs_control(value_col = "mean_pos")

tmp_zr <- summ_zr %>%
  filter(as.character(Time) %in% time_levels_small) %>%
  add_log2fc_vs_control(value_col = "mean_pos")

all_vals <- c(tmp_t47d$log2FC_vs_ctl0, tmp_zr$log2FC_vs_ctl0)
all_vals <- abs(all_vals[is.finite(all_vals)])

shared_lim_fc <- if (length(all_vals) == 0) {
  1
} else {
  max(0.25, unname(quantile(all_vals, 0.95, na.rm = TRUE)))
}

# =========================================================
# Final plots
# =========================================================

p_fc_t47d <- plot_heatmap_fc_small(
  summ = summ_t47d,
  title = "T-47D",
  value_col = "mean_pos",
  shared_limit = shared_lim_fc,
  cross_on_na = TRUE
)

p_fc_zr <- plot_heatmap_fc_small(
  summ = summ_zr,
  title = "ZR-75-1",
  value_col = "mean_pos",
  shared_limit = shared_lim_fc,
  cross_on_na = TRUE
)

fig_fc_small <- (p_fc_t47d | p_fc_zr) +
  plot_layout(guides = "collect") &
  theme(
    legend.position = "right"
  )

print(fig_fc_small)
