)

# ------------------------------------------------------------
# 2) Add axis labels far from the axes
# ------------------------------------------------------------
add_far_axis_labels <- function(
    s3d,
    xr,
    yr,
    zr,
    z0,
    xlab = "HLA-C",
    ylab = "HLA-A",
    zlab = "CTL score",
    cex_lab = 1.30
) {
  
  usr <- par("usr")
  dx <- diff(usr[1:2])
  dy <- diff(usr[3:4])
  
  # X-axis label: move a bit lower
  x_mid <- s3d$xyz.convert(
    x = mean(xr),
    y = yr[1],
    z = z0
  )
  
  text(
    x = x_mid$x,
    y = x_mid$y - 0.24 * dy,
    labels = xlab,
    cex = cex_lab,
    font = 2
  )
  
  # Y-axis label: move farther right and slightly lower
  y_mid <- s3d$xyz.convert(
    x = xr[2],
    y = mean(yr),
    z = z0
  )
  
  text(
    x = y_mid$x + 0.30 * dx,
    y = y_mid$y - 0.03 * dy,
    labels = ylab,
    srt = 55,
    cex = cex_lab,
    font = 2
  )
  
  # Z-axis label: keep as is
  z_mid <- s3d$xyz.convert(
    x = xr[1],
    y = yr[1],
    z = mean(zr)
  )
  
  text(
    x = z_mid$x - 0.20 * dx,
    y = z_mid$y,
    labels = zlab,
    srt = 90,
    cex = cex_lab,
    font = 2
  )
}
# ------------------------------------------------------------
# 3) Main plotting function
# ------------------------------------------------------------

plot_3d_scores <- function(
    csv_file,
    main_title,
    draw_high_on_top = FALSE,
    legend_cex = 0.8,
    point_cex = 0.6,
    stem_lwd = 0.7,
    angle_val = 55
) {
  
  # Load data
  df <- read.csv(csv_file, stringsAsFactors = FALSE)
  
  # Check required columns
  required_cols <- c("x", "y", "z", "group")
  missing_cols <- setdiff(required_cols, colnames(df))
  
  if (length(missing_cols) > 0) {
    stop("Missing columns in ", csv_file, ": ", paste(missing_cols, collapse = ", "))
  }
  
  # Set group order
  df$group <- factor(df$group, levels = c("Low", "Intermediate", "High"))
  
  # Optional: draw High samples last
  if (draw_high_on_top) {
    df <- df[order(df$group), ]
  }
  
  # Colors
  point_cols <- group_cols[as.character(df$group)]
  stem_cols  <- adjustcolor(point_cols, alpha.f = 0.35)
  
  # Axis ranges
  xr <- range(df$x, na.rm = TRUE)
  yr <- range(df$y, na.rm = TRUE)
  zr <- range(df$z, na.rm = TRUE)
  z0 <- zr[1]
  
  # Margins
  par(mar = c(5, 5, 3, 9), xpd = NA)
  
  # Base 3D plot
  s3d <- scatterplot3d(
    x = df$x,
    y = df$y,
    z = df$z,
    type = "n",
    angle = angle_val,
    scale.y = 1,
    box = FALSE,
    grid = FALSE,
    xlab = "",
    ylab = "",
    zlab = "",
    main = main_title,
    cex.axis = 0.9
  )
  
  # Draw stems
  for (i in seq_len(nrow(df))) {
    s3d$points3d(
      x = c(df$x[i], df$x[i]),
      y = c(df$y[i], df$y[i]),
      z = c(z0, df$z[i]),
      type = "l",
      col = stem_cols[i],
      lwd = stem_lwd
    )
  }
  
  # Draw points
  s3d$points3d(
    x = df$x,
    y = df$y,
    z = df$z,
    col = point_cols,
    pch = 16,
    cex = point_cex
  )
  
  # Add distant axis labels
  add_far_axis_labels(
    s3d = s3d,
    xr = xr,
    yr = yr,
    zr = zr,
    z0 = z0,
    xlab = "HLA-C",
    ylab = "HLA-A",
    zlab = "CTL score",
    cex_lab = 1.30
  )
  
  # Add legend
  usr <- par("usr")
  
  legend(
    x = usr[2] + 0.04 * diff(usr[1:2]),
    y = usr[4],
    legend = c("Low", "Intermediate", "High"),
    title = "KAMPR",
    col = group_cols[c("Low", "Intermediate", "High")],
    pch = 16,
    pt.cex = 1.0,
    bty = "n",
    xjust = 0,
    yjust = 1,
    cex = legend_cex
  )
  
  invisible(s3d)
}

