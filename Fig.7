df <- read.csv("Pooled_multi_cancer_KM_2026-04-21.csv", stringsAsFactors = FALSE)

# Clean group names
df <- df %>%
  mutate(
    combo_plot = combo,
    combo_plot = str_replace_all(combo_plot, "LINC00885", "KAMPR"),
    combo_plot = str_replace_all(combo_plot, "QS_CTL", "CTL"),
    combo_plot = factor(combo_plot, levels = group_levels)
  ) %>%
  filter(
    !is.na(combo_plot),
    !is.na(time),
    !is.na(event)
  )

# ============================================================
# 5) Patient numbers
# ============================================================

n_by_group <- df %>%
  count(combo_plot, name = "n") %>%
  mutate(
    combo_plot = factor(as.character(combo_plot), levels = group_levels),
    prop = n / sum(n)
  ) %>%
  arrange(combo_plot)

n_total <- nrow(df)
n_vec <- setNames(n_by_group$n, as.character(n_by_group$combo_plot))

cat("\nNumber of patients per group:\n")
print(n_by_group)

cat("\nTotal n =", n_total, "\n\n")

# ============================================================
# 6) Targeted log-rank test
# ============================================================

target_group <- "HLA-A_Low | KAMPR_High | CTL_Low"

df_test <- df %>%
  mutate(
    comparison_group = ifelse(combo_plot == target_group, "Target", "Other"),
    comparison_group = factor(comparison_group, levels = c("Other", "Target"))
  )

logrank_res <- survdiff(Surv(time, event) ~ comparison_group, data = df_test)

pval_target <- 1 - pchisq(
  logrank_res$chisq,
  df = length(logrank_res$n) - 1
)

pval_label <- paste0(
  "p = ",
  format.pval(pval_target, digits = 2, eps = 1e-4)
)

cat("\nLog-rank test: target group vs others\n")
print(logrank_res)
cat("p-value =", signif(pval_target, 4), "\n\n")

# ============================================================
# 7) Survival curve data
# ============================================================

fit <- survfit(Surv(time, event) ~ combo_plot, data = df)

surv_df <- surv_summary(fit, data = df) %>%
  mutate(
    combo_clean = str_remove(strata, "^combo_plot="),
    combo_clean = factor(combo_clean, levels = group_levels)
  )

