  bquote("HLA-A"^Low  ~ "|" ~ "KAMPR"^High ~ "|" ~ "CTL"^Low  ~ "  n = " ~ .(n_vec["HLA-A_Low | KAMPR_High | CTL_Low"])),
  bquote("HLA-A"^High ~ "|" ~ "KAMPR"^Low  ~ "|" ~ "CTL"^High ~ "  n = " ~ .(n_vec["HLA-A_High | KAMPR_Low | CTL_High"])),
  bquote("HLA-A"^High ~ "|" ~ "KAMPR"^High ~ "|" ~ "CTL"^High ~ "  n = " ~ .(n_vec["HLA-A_High | KAMPR_High | CTL_High"]))
)

