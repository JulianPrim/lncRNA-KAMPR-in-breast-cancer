# ============================================================
# ANALYSIS OF FELINE TRIAL DATA downloaded at GSE211434
# Row 1: cancer-cell UMAP by day, colored by response
# Row 2: pooled percentage of KAMPR+ cancer cells
# Row 3: KAMPR expression in KAMPR+ cancer cells
# data were first merged into a global rds file named: FELINE_allcells_Seurat.rds
# ============================================================

suppressPackageStartupMessages({
  library(Seurat)
  library(dplyr)
  library(ggplot2)
  library(patchwork)
  library(scales)
  library(grid)
})

dir.create("plots", showWarnings = FALSE, recursive = TRUE)

# ------------------------------------------------------------
# 0) Parameters
# ------------------------------------------------------------

rds_path <- "FELINE_allcells_Seurat.rds"

gene_use <- "LINC00885"
gene_label_plot <- "KAMPR"

treatment_target <- "Letrozole alone"

n_hvg <- 3000
n_pcs <- 20
cluster_res <- 0.4

day_levels <- c("D0", "D14", "D180")

condition_cols <- c(
  "Response"     = "#4E79A7",
  "Non-Response" = "#E15759"
)

# ------------------------------------------------------------
# 1) Plot themes
# ------------------------------------------------------------

theme_feline_clean <- function(base_size = 10) {
  theme_classic(base_size = base_size) +
    theme(
      axis.line = element_line(color = "black", linewidth = 0.35),
      axis.ticks = element_line(color = "black", linewidth = 0.35),
      axis.text = element_text(color = "black"),
      axis.title = element_text(face = "bold", color = "black"),
      strip.background = element_blank(),
      strip.text = element_text(face = "bold", size = base_size + 1),
      legend.title = element_text(face = "bold", size = base_size),
      legend.text = element_text(size = base_size - 1),
      plot.title = element_text(face = "bold", hjust = 0.5),
      plot.subtitle = element_text(hjust = 0.5, color = "grey30"),
      panel.spacing = unit(1.0, "lines")
    )
}

theme_umap_response <- function(base_size = 10) {
  theme_void(base_size = base_size) +
    theme(
      strip.background = element_blank(),
      strip.text = element_text(face = "bold", size = base_size + 1),
      legend.title = element_text(face = "bold", size = base_size),
      legend.text = element_text(size = base_size - 1),
      plot.title = element_text(face = "bold", hjust = 0.5),
      plot.subtitle = element_text(hjust = 0.5, color = "grey30"),
      panel.spacing = unit(1.0, "lines"),
      plot.margin = margin(4, 6, 2, 6)
    )
}

# ------------------------------------------------------------
# 2) Load global Seurat object
# ------------------------------------------------------------

if (!file.exists(rds_path)) {
  stop("File not found: ", rds_path)
}

obj <- readRDS(rds_path)

if (!inherits(obj, "Seurat")) {
  stop("The loaded object is not a Seurat object.")
}

DefaultAssay(obj) <- "RNA"

cat("\nLoaded object: ", rds_path, "\n")
cat("Dimensions: ", nrow(obj), " features x ", ncol(obj), " cells\n", sep = "")

# ------------------------------------------------------------
# 3) Check required metadata
# ------------------------------------------------------------

meta_cols <- colnames(obj@meta.data)

needed_global <- c("Treatment", "Day", "CellType", "CellTypeSubtype")
missing_global <- setdiff(needed_global, meta_cols)

if (length(missing_global) > 0) {
  stop("Missing metadata columns: ", paste(missing_global, collapse = ", "))
}

if (!("Patient" %in% meta_cols || "patient_id" %in% meta_cols)) {
  stop("No patient column found: neither 'Patient' nor 'patient_id'.")
}

if (!(gene_use %in% rownames(obj))) {
  stop(gene_use, " is not present in the Seurat object.")
}

patient_col <- if ("Patient" %in% meta_cols) "Patient" else "patient_id"

# ------------------------------------------------------------
# 4) Clean and harmonize metadata
# ------------------------------------------------------------

obj$Treatment_plot <- trimws(as.character(obj$Treatment))
obj$CellType_plot <- as.character(obj$CellType)
obj$CellTypeSubtype_plot <- as.character(obj$CellTypeSubtype)
obj$Patient_plot <- as.character(obj@meta.data[[patient_col]])

# Harmonize day labels
day_raw <- as.character(obj$Day)
day_raw <- gsub("^D", "", day_raw, ignore.case = TRUE)

obj$Day_plot <- factor(
  day_raw,
  levels = c("0", "14", "180"),
  labels = c("D0", "D14", "D180")
)

# Build binary clinical response
if ("ResponseBin" %in% colnames(obj@meta.data)) {
  
  resp_bin <- trimws(as.character(obj$ResponseBin))
  
  obj$ResponseBin <- case_when(
    resp_bin %in% c("Response", "Responder", "Yes", "Y", "1", "TRUE", "True") ~ "Response",
    resp_bin %in% c("Non-response", "Non-Response", "Non responder", "Nonresponder",
                    "NR", "No", "N", "0", "FALSE", "False") ~ "Non-response",
    TRUE ~ NA_character_
  )
  
} else if ("ResponseYN" %in% colnames(obj@meta.data)) {
  
  respyn <- trimws(as.character(obj$ResponseYN))
  
  obj$ResponseBin <- case_when(
    respyn %in% c("Response", "Responder", "R", "Yes", "Y", "1", "TRUE", "True") ~ "Response",
    respyn %in% c("Non-response", "Non-Response", "Non responder", "Nonresponder",
                  "NR", "No", "N", "0", "FALSE", "False") ~ "Non-response",
    TRUE ~ NA_character_
  )
  
} else if ("Response" %in% colnames(obj@meta.data)) {
  
  resp <- trimws(as.character(obj$Response))
  
  obj$ResponseBin <- case_when(
    resp %in% c("Sustained response", "Partial response", "Response", "Responder") ~ "Response",
    resp %in% c("Stable disease", "Rebound disease", "Progressive disease",
                "Non-response", "Non-Response", "Non responder", "Nonresponder") ~ "Non-response",
    TRUE ~ NA_character_
  )
  
} else {
  stop("Cannot build ResponseBin: no ResponseBin, ResponseYN, or Response column found.")
}

obj$ResponseBin <- factor(obj$ResponseBin, levels = c("Response", "Non-response"))

cat("\nTreatment_plot:\n")
