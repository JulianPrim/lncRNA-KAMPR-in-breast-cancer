################################################################################
### Violin plot of the immune score on responsive to letrozole compared to resistant biopsies
### Deconvolution made with ConsensusTME
################################################################################

suppressPackageStartupMessages({
  library(readr)
  library(dplyr)
  library(ggplot2)
})

## 1) Charger la table
deconv_long <- readr::read_tsv(
  "deconv_long_with_clinical_LINC00885.tsv",
  show_col_types = FALSE
)

## 2) Filtrer : Letrozole, consensus_tme, immune score
imm_score <- deconv_long %>%
  filter(
    method == "consensus_tme",
    clinical_label %in% c("Resp to Let", "Resist to Let"),
    cell_type == "immune score"
  ) %>%
  select(
    biopsie_id,
    clinical_label,
    ImmuneScore_cons = score
  ) %>%
  filter(!is.na(ImmuneScore_cons)) %>%
  mutate(
    clinical_label = factor(
      clinical_label,
      levels = c("Resp to Let", "Resist to Let")
    )
  )

## 3) Test Wilcoxon
w_imm <- wilcox.test(
  ImmuneScore_cons ~ clinical_label,
  data = imm_score
)

subtitle_txt <- paste0("Wilcoxon p = ", signif(w_imm$p.value, 3))

## 4) Couleurs pastel

paper_cols <- c(
  "Resp to Let"   = "#8EC5A4",   # vert pastel
  "Resist to Let" = "#E6D85C"    # jaune pastel
)
## 5) Plot
p_imm_violin <- ggplot(
  imm_score,
  aes(x = clinical_label, y = ImmuneScore_cons, fill = clinical_label)
) +
  geom_violin(
    trim = FALSE,
    width = 0.82,
    color = "black",
    linewidth = 0.6,
    alpha = 0.85
  ) +
  geom_boxplot(
    width = 0.10,
    outlier.shape = NA,
    fill = "white",
    color = "black",
    linewidth = 0.35
  ) +
  stat_summary(
    fun = median,
    geom = "crossbar",
    width = 0.08,
    linewidth = 0.8,
    color = "black"
  ) +
  scale_fill_manual(values = paper_cols, guide = "none") +
  labs(
    title = "Immune infiltration",
    subtitle = subtitle_txt,
    x = NULL,
    y = "Immune score (ConsensusTME)"
  ) +
  theme_classic(base_size = 9) +
  theme(
    plot.title = element_text(face = "bold", size = 10, hjust = 0.5),
    plot.subtitle = element_text(size = 8, hjust = 0.5, color = "grey30"),
    axis.title.y = element_text(size = 9, color = "black"),
    axis.text.x = element_text(
      size = 8,
      color = "black",
      angle = 45,
      hjust = 1,
      vjust = 1
    ),
    axis.text.y = element_text(size = 8, color = "black"),
    axis.line = element_line(linewidth = 0.4, color = "black"),
    axis.ticks = element_line(linewidth = 0.4, color = "black"),
    legend.position = "none"
  )

print(p_imm_violin)

