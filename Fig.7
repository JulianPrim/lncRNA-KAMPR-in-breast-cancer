## =========================================================
## Show KAMPR differential expression inside each patient with paired biopsies of responsive then acquired resistance
## - Loads deconv_long from disk
## =========================================================

suppressPackageStartupMessages({
  library(readr)
  library(dplyr)
  library(tidyr)
  library(stringr)
  library(ggplot2)
  library(patchwork)
})

## -------------------------
## 0) Load data 
## -------------------------
deconv_file <- "deconv_long_with_clinical_LINC00885.tsv"  
stopifnot(file.exists(deconv_file))
deconv_long <- readr::read_tsv(deconv_file, show_col_types = FALSE)

req <- c("biopsie_id","clinical_label","method","cell_type","score","LINC00885")
miss <- setdiff(req, names(deconv_long))
if (length(miss) > 0) stop("Missing columns in deconv_long: ", paste(miss, collapse = ", "))

## -------------------------
## 1) Settings
## -------------------------
drug_label <- c(Let = "Letrozole", Tam = "Tamoxifen")
cols       <- c("Letrozole" = "lightcoral", "Tamoxifen" = "steelblue")

exclude_patients <- c("015","017","018")
priority_good    <- c("007","024","006","016","026","019","020")

highlight_fill  <- "lightgoldenrod1"
highlight_alpha <- 0.35

## -------------------------
## 2) Build per-biopsy table (robust to duplicates)
## -------------------------
imm_per_biopsy <- deconv_long %>%
  dplyr::filter(method == "consensus_tme", cell_type == "immune score") %>%
  dplyr::select(biopsie_id, ImmuneScore = score)

meta_per_biopsy <- deconv_long %>%
  group_by(biopsie_id, clinical_label) %>%
  summarise(
    LINC00885 = dplyr::first(LINC00885[!is.na(LINC00885)]),
    .groups = "drop"
  ) %>%
  mutate(
    patient_id = str_extract(biopsie_id, "^[0-9]{3}"),
    sample_id  = biopsie_id,
    sample_num = suppressWarnings(as.numeric(str_extract(sample_id, "(?<=^[0-9]{3}-)\\d+")))
  ) %>%
  rename(KAMPR = LINC00885)

df_biopsy <- meta_per_biopsy %>%
  left_join(imm_per_biopsy, by = "biopsie_id")

## -------------------------
## 3) Parse treatment/state + remove "Rec on Let" + EXCLUDE patients
## -------------------------
df2 <- df_biopsy %>%
  mutate(
    drug_code = case_when(
      str_detect(clinical_label, regex("Let", TRUE)) ~ "Let",
      str_detect(clinical_label, regex("Tam", TRUE)) ~ "Tam",
      TRUE ~ NA_character_
    ),
    state = case_when(
      str_detect(clinical_label, regex("^\\s*Resp", TRUE))      ~ "Responsive",
      str_detect(clinical_label, regex("^\\s*Resist", TRUE))    ~ "Resistant",
      str_detect(clinical_label, regex("^\\s*Rec\\s+on", TRUE)) ~ "Resistant",
      TRUE ~ NA_character_
    ),
    rec_on_let = str_detect(clinical_label, regex("^\\s*Rec\\s*on\\s*Let", TRUE)),
    Treatment  = drug_label[drug_code]
  ) %>%
  filter(!is.na(Treatment), !is.na(state), !rec_on_let) %>%
  filter(!patient_id %in% exclude_patients)

## -------------------------
## 4) Helper: compute Δ table (paired + cross-drug)
## -------------------------
make_delta_table <- function(df_in, value_col) {
  
  df_summ <- df_in %>%
    filter(!is.na(.data[[value_col]])) %>%
    group_by(patient_id, Treatment, state) %>%
    summarise(value = mean(.data[[value_col]], na.rm = TRUE), .groups = "drop")
  
  resp_last <- df_in %>%
    filter(state == "Responsive", !is.na(.data[[value_col]])) %>%
    group_by(patient_id) %>%
    arrange(sample_num, .by_group = TRUE) %>%
    summarise(resp_last = dplyr::last(.data[[value_col]]), .groups = "drop")
  
  paired_all <- df_summ %>%
    pivot_wider(names_from = state, values_from = value) %>%
    filter(!is.na(Responsive), !is.na(Resistant)) %>%
    mutate(delta = Resistant - Responsive)
  
  cross_all <- df_in %>%
    filter(state == "Resistant", !is.na(.data[[value_col]])) %>%
    group_by(patient_id, Treatment) %>%
    summarise(res_drug = mean(.data[[value_col]], na.rm = TRUE), .groups = "drop") %>%
    inner_join(resp_last, by = "patient_id") %>%
    mutate(delta = res_drug - resp_last) %>%
    anti_join(paired_all %>% select(patient_id, Treatment),
              by = c("patient_id", "Treatment"))
  
  bind_rows(
    paired_all %>% select(patient_id, Treatment, delta),
    cross_all  %>% select(patient_id, Treatment, delta)
  ) %>%
    filter(is.finite(delta))
}

df_kampr <- make_delta_table(df2, "KAMPR")
df_imm   <- make_delta_table(df2, "ImmuneScore")

## -------------------------
## 5) Patient universe + Order
## -------------------------
patient_universe <- sort(unique(c(df_kampr$patient_id, df_imm$patient_id)))

pat_k <- df_kampr %>% group_by(patient_id) %>% summarise(delta_k = median(delta), .groups = "drop")
pat_i <- df_imm   %>% group_by(patient_id) %>% summarise(delta_i = median(delta), .groups = "drop")

pat_sum <- tibble(patient_id = patient_universe) %>%
  left_join(pat_k, by = "patient_id") %>%
  left_join(pat_i, by = "patient_id") %>%
  mutate(
    good = is.finite(delta_k) & is.finite(delta_i) & delta_k > 0 & delta_i < 0,
    score = ifelse(is.finite(delta_k), delta_k, -Inf) -
      ifelse(is.finite(delta_i), delta_i, Inf),
    priority_rank = match(patient_id, priority_good),
    priority_rank = ifelse(is.na(priority_rank), Inf, priority_rank)
  )

good_order <- pat_sum %>%
  filter(good) %>%
  arrange(priority_rank, desc(delta_k), delta_i, patient_id) %>%
  pull(patient_id)

other_order <- pat_sum %>%
  filter(!good) %>%
  arrange(desc(score), patient_id) %>%
  pull(patient_id)

patient_levels_top   <- c(good_order, other_order)
levels_bottom_to_top <- rev(patient_levels_top)
good6_top <- head(good_order, 6)

df_kampr2 <- df_kampr %>% mutate(patient_id_f = factor(patient_id, levels = levels_bottom_to_top))
df_imm2   <- df_imm   %>% mutate(patient_id_f = factor(patient_id, levels = levels_bottom_to_top))

## -------------------------
## 6) Highlight band behind TOP 6 good profiles
## -------------------------
levs <- levels(df_kampr2$patient_id_f)
idx  <- match(good6_top, levs)
idx  <- idx[!is.na(idx)]

highlight_band <- if (length(idx) > 0) {
  data.frame(
    xmin = -Inf, xmax = Inf,
    ymin = min(idx) - 0.5,
    ymax = max(idx) + 0.5
  )
} else NULL

## -------------------------
## 7) Wilcoxon p-value only (same settings as reference)
## -------------------------
wilcox_p_only <- function(delta_vec) {
  delta_vec <- delta_vec[is.finite(delta_vec)]
  if (length(delta_vec) == 0) return(NA_real_)
  wilcox.test(delta_vec, mu = 0, conf.int = TRUE, conf.level = 0.95, exact = FALSE)$p.value
}

p_k <- wilcox_p_only(df_kampr2$delta)
p_i <- wilcox_p_only(df_imm2$delta)

sub_k <- if (is.finite(p_k)) paste0("Wilcoxon (μ=0): p = ", format.pval(p_k, digits = 3, eps = 1e-3)) else "Wilcoxon (μ=0): p = NA"
sub_i <- if (is.finite(p_i)) paste0("Wilcoxon (μ=0): p = ", format.pval(p_i, digits = 3, eps = 1e-3)) else "Wilcoxon (μ=0): p = NA"

## -------------------------
## 8) Plot function (+ subtitle p only)
## -------------------------
plot_delta <- function(df_plot, title, subtitle, xlab, show_y = TRUE) {
  
  ggplot(df_plot, aes(x = delta, y = patient_id_f, color = Treatment)) +
    { if (!is.null(highlight_band))
      geom_rect(
        data = highlight_band,
        aes(xmin = xmin, xmax = xmax, ymin = ymin, ymax = ymax),
        inherit.aes = FALSE,
        fill = highlight_fill,
        alpha = highlight_alpha,
        color = NA
      )
    } +
    geom_vline(xintercept = 0, linetype = 2) +
    geom_point(shape = 16, size = 2,
               position = position_jitter(width = 0, height = 0.08)) +
    scale_color_manual(values = cols, drop = TRUE, name = "") +
    scale_y_discrete(drop = TRUE) +
    labs(
      title = title,
      subtitle = subtitle,
      x = xlab,
      y = if (show_y) "aR patients" else NULL
    ) +
    theme_minimal(base_size = 10) +
    theme(
      legend.position = "right",
      plot.title = element_text(margin = margin(b = 4)),
      plot.subtitle = element_text(margin = margin(b = 8), color = "grey25"),
      panel.grid.major.y = element_blank(),
      panel.grid.minor.y = element_blank()
    ) +
    guides(color = guide_legend(override.aes = list(shape = 16)))
}

p_kampr <- plot_delta(
  df_kampr2,
  title    = "Δ KAMPR",
  subtitle = sub_k,
  xlab     = expression(Delta~"KAMPR (Resist \u2212 Resp)"),
  show_y   = TRUE
)

p_imm <- plot_delta(
  df_imm2,
  title    = "Δ Immune score",
  subtitle = sub_i,
  xlab     = expression(Delta~"Immune score (Resist \u2212 Resp)"),
  show_y   = FALSE
) +
  theme(axis.text.y = element_blank(),
        axis.ticks.y = element_blank())

(p_kampr | p_imm) +
  plot_layout(guides = "collect") &
  theme(legend.position = "right")

